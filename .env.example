# Copiază acest fișier în .env și completează valorile reale.
# .env NU trebuie comis în git (vezi .gitignore).

# --- Bază de date ---
DB_HOST=localhost
DB_NAME=stepupfloor
DB_USER=root
DB_PASS=
DB_CHARSET=utf8mb4

# --- Autentificare admin ---
ADMIN_USER=admin
# Generează cu: php -r "echo password_hash('parola-ta', PASSWORD_BCRYPT);"
ADMIN_PASS_HASH=

# Notă: cheile Stripe (secret / publishable / webhook) sunt stocate în
# tabelul `settings` din baza de date și se editează din Admin → Setări.
